                           <span className="text-[10px] font-black text-text-secondary/30 uppercase tracking-[0.2em]">Distribución NPS por Periodo</span>
                            <h4 className="text-lg font-black text-text-primary uppercase tracking-tight">Análisis NPS por Periodo</h4>
