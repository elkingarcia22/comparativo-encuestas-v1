                          <Filter className="h-3.5 w-3.5" />
                          <span>Demográficos</span>
                          {getActiveFiltersCount('nps').total > 0 && (
                            <span className="flex items-center justify-center bg-white text-brand text-[10px] font-black h-5 min-w-[20px] px-1 rounded-full ml-1">
                              {getActiveFiltersCount('nps').total}
                            </span>
                          )}
                        </Button>
                      </div>
                    </div>
                  </CardHeader>

                  <CardContent className="p-0">
                    <div className="grid grid-cols-1 xl:grid-cols-2">
