                        <p className="text-xs text-text-muted font-bold uppercase tracking-wider opacity-60">Lealtad y recomendación de los colaboradores</p>
                      </div>

                       <div className="flex items-center p-1 bg-surface-subtle rounded-xl border border-border/20">
                        <Button 
