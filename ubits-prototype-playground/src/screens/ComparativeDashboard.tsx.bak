                            <span className="text-[10px] font-black text-text-secondary/30 uppercase tracking-[0.2em]">Evolución Temporal</span>
                            <h4 className="text-lg font-black text-text-primary uppercase tracking-tight">Tendencia de Respuesta</h4>
                          </div>
                          <div className="h-10 w-10 rounded-xl bg-muted/30 flex items-center justify-center text-text-secondary/40">
                            <TrendingUp className="h-5 w-5" />
                          </div>
                         </div>
                         
                         <div className="flex-1 min-h-[400px]">
                           <TrendMetricLineChart 
